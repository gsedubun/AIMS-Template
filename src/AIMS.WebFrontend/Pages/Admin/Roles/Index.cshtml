@page
@model AIMS.WebFrontend.Pages.Admin.Roles.IndexModel
@{
    ViewData["Title"] = "Role Management";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Role Management</h1>
    <a asp-page="Create" class="btn btn-primary">
        <i class="bi bi-plus-circle"></i> Add New Role
    </a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="card">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>Role Name</th>
                        <th>Description</th>
                        <th>Users in Role</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var role in Model.Roles)
                    {
                        <tr>
                            <td>
                                <strong>@role.Name</strong>
                                @if (role.Name == "Admin")
                                {
                                    <span class="badge bg-warning text-dark ms-2">System</span>
                                }
                            </td>
                            <td>@(role.Description ?? "-")</td>
                            <td>
                                <span class="badge bg-secondary">@role.UserCount users</span>
                            </td>
                            <td>
                                <div class="btn-group btn-group-sm">
                                    <a asp-page="Edit" asp-route-id="@role.Id" class="btn btn-outline-primary">
                                        Edit
                                    </a>
                                    @if (role.Name != "Admin")
                                    {
                                        <button type="button" class="btn btn-outline-danger" 
                                                data-bs-toggle="modal" 
                                                data-bs-target="#deleteModal-@role.Id.Replace("-", "")"
                                                @(role.UserCount > 0 ? "disabled" : "")
                                                title="@(role.UserCount > 0 ? "Cannot delete role with assigned users" : "Delete")">
                                            Delete
                                        </button>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @if (!Model.Roles.Any())
        {
            <div class="alert alert-info">
                No roles found. Click "Add New Role" to create one.
            </div>
        }
    </div>
</div>

<!-- Delete Confirmation Modals -->
@foreach (var role in Model.Roles.Where(r => r.Name != "Admin" && r.UserCount == 0))
{
    <div class="modal fade" id="deleteModal-@role.Id.Replace("-", "")" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Confirm Delete</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    Are you sure you want to delete the role <strong>@role.Name</strong>?
                    <br><br>
                    <span class="text-danger">This action cannot be undone.</span>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <form method="post" asp-page-handler="Delete" asp-route-id="@role.Id" style="display: inline;">
                        <button type="submit" class="btn btn-danger">Delete</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
}
