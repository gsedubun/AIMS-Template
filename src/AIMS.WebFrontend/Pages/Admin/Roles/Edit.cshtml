@page "{id}"
@model AIMS.WebFrontend.Pages.Admin.Roles.EditModel
@{
    ViewData["Title"] = "Edit Role";
}

<h1>Edit Role</h1>

<div class="row">
    <div class="col-md-6">
        <div class="card">
            <div class="card-body">
                <form method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                    <input type="hidden" asp-for="Input.Id" />

                    <div class="mb-3">
                        <label asp-for="Input.Name" class="form-label"></label>
                        @if (Model.Input.Name == "Admin")
                        {
                            <input asp-for="Input.Name" class="form-control" readonly />
                            <small class="text-muted">The Admin role name cannot be changed.</small>
                        }
                        else
                        {
                            <input asp-for="Input.Name" class="form-control" />
                        }
                        <span asp-validation-for="Input.Name" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Input.Description" class="form-label"></label>
                        <textarea asp-for="Input.Description" class="form-control" rows="3"></textarea>
                        <span asp-validation-for="Input.Description" class="text-danger"></span>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">Save Changes</button>
                        <a asp-page="Index" class="btn btn-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="col-md-6">
        <div class="card">
            <div class="card-header">
                <h5 class="card-title mb-0">Users in this Role</h5>
            </div>
            <div class="card-body">
                @if (Model.UsersInRole.Any())
                {
                    <ul class="list-group">
                        @foreach (var user in Model.UsersInRole)
                        {
                            <li class="list-group-item d-flex justify-content-between align-items-center">
                                <div>
                                    <strong>@user.FullName</strong>
                                    <br><small class="text-muted">@user.Email</small>
                                </div>
                                <a asp-page="../Users/Roles" asp-route-id="@user.Id" class="btn btn-sm btn-outline-secondary">
                                    Manage Roles
                                </a>
                            </li>
                        }
                    </ul>
                }
                else
                {
                    <p class="text-muted">No users are assigned to this role.</p>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
