@page
@model AIMS.WebFrontend.Pages.Account.LogoutModel
@{
    ViewData["Title"] = "Logout";
    Layout = "_LoginLayout";
}

<div class="text-center mt-5">
    <h1>You have been logged out</h1>
    <p class="lead text-muted">Thank you for using AIMS.</p>
    <div class="mt-4">
        <a asp-page="/Index" class="btn btn-primary">Return to Home</a>
        <a asp-page="/Account/Login" class="btn btn-outline-secondary">Login Again</a>
    </div>
</div>
