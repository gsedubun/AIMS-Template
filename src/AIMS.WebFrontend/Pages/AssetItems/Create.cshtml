@page
@model AIMS.WebFrontend.Pages.AssetItems.CreateModel
@using AIMS.Core.Entities
@{
    ViewData["Title"] = "Create Asset Item";
}

<div class="row">
    <div class="col-md-8 offset-md-2">
        <h1>Create New Asset Item</h1>
        <hr />

        <form method="post" class="needs-validation">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

            <div class="mb-3">
                <label asp-for="Input.AssetId" class="form-label">Asset ID <span class="text-danger">*</span></label>
                <input asp-for="Input.AssetId" class="form-control" placeholder="Enter unique asset identifier">
                <span asp-validation-for="Input.AssetId" class="d-block mt-1 text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Input.Title" class="form-label">Title <span class="text-danger">*</span></label>
                <input asp-for="Input.Title" class="form-control" placeholder="Enter asset item title">
                <span asp-validation-for="Input.Title" class="d-block mt-1 text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Input.Description" class="form-label">Description</label>
                <textarea asp-for="Input.Description" class="form-control" rows="3" placeholder="Enter asset item description"></textarea>
                <span asp-validation-for="Input.Description" class="d-block mt-1 text-danger"></span>
            </div>

            <div class="row">
                <div class="col-md-6">
                    <div class="mb-3">
                        <label asp-for="Input.Type" class="form-label">Asset Type <span class="text-danger">*</span></label>
                        <select asp-for="Input.Type" class="form-select">
                            <option value="">-- Select Type --</option>
                            @foreach (AssetType type in Enum.GetValues(typeof(AssetType)))
                            {
                                <option value="@type">@type</option>
                            }
                        </select>
                        <span asp-validation-for="Input.Type" class="d-block mt-1 text-danger"></span>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="mb-3">
                        <label asp-for="Input.Location" class="form-label">Location</label>
                        <input asp-for="Input.Location" class="form-control" placeholder="Enter asset location">
                        <span asp-validation-for="Input.Location" class="d-block mt-1 text-danger"></span>
                    </div>
                </div>
            </div>

            <div class="row">
                <div class="col-md-6">
                    <div class="mb-3">
                        <label asp-for="Input.Priority" class="form-label">Priority <span class="text-danger">*</span></label>
                        <select asp-for="Input.Priority" class="form-select">
                            <option value="">-- Select Priority --</option>
                            @foreach (AssetPriority priority in Enum.GetValues(typeof(AssetPriority)))
                            {
                                <option value="@priority">@priority</option>
                            }
                        </select>
                        <span asp-validation-for="Input.Priority" class="d-block mt-1 text-danger"></span>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="mb-3">
                        <label asp-for="Input.IntegrityStatus" class="form-label">Integrity Status <span class="text-danger">*</span></label>
                        <select asp-for="Input.IntegrityStatus" class="form-select">
                            <option value="">-- Select Status --</option>
                            @foreach (IntegrityStatus status in Enum.GetValues(typeof(IntegrityStatus)))
                            {
                                <option value="@status">@status</option>
                            }
                        </select>
                        <span asp-validation-for="Input.IntegrityStatus" class="d-block mt-1 text-danger"></span>
                    </div>
                </div>
            </div>

            <div class="form-group mt-4">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-plus-circle"></i> Create Asset Item
                </button>
                <a asp-page="Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
