@page "{id:int}"
@model AIMS.WebFrontend.Pages.AssetItems.DetailsModel
@using AIMS.Core.Entities
@{
    ViewData["Title"] = "Asset Item Details";
}

<style>
    .detail-card {
        border-left: 4px solid #0d6efd;
        margin-bottom: 1.5rem;
    }

    .detail-row {
        display: flex;
        padding: 0.75rem 0;
        border-bottom: 1px solid #e9ecef;
    }

    .detail-row:last-child {
        border-bottom: none;
    }

    .detail-label {
        font-weight: 600;
        color: #495057;
        min-width: 150px;
        width: 25%;
    }

    .detail-value {
        color: #212529;
        flex: 1;
        word-break: break-word;
    }

    .remark-item {
        border-left: 3px solid #6c757d;
        padding: 0.75rem 1rem;
        margin-bottom: 1rem;
        background-color: #f8f9fa;
        border-radius: 0.25rem;
    }

    .remark-item.new {
        border-left-color: #28a745;
        background-color: #f0fff4;
    }

    .remark-time {
        font-size: 0.875rem;
        color: #6c757d;
        margin-top: 0.5rem;
    }

    .remark-content {
        color: #212529;
        margin-top: 0.5rem;
        line-height: 1.5;
    }

    .timeline-container {
        position: relative;
        padding-left: 2rem;
    }

    .timeline-container::before {
        content: '';
        position: absolute;
        left: 0;
        top: 0;
        bottom: 0;
        width: 2px;
        background-color: #dee2e6;
    }
</style>

<!-- Header -->
<div class="mb-4">
    <a asp-page="Index" class="btn btn-outline-secondary mb-3">
        <i class="fas fa-arrow-left"></i> Back to Assets
    </a>
</div>

<!-- Asset Details Card -->
<div class="card detail-card shadow-sm mb-4">
    <div class="card-header bg-light d-flex justify-content-between align-items-center">
        <div>
            <h3 class="mb-1">@Model.AssetItem.Title</h3>
            <small class="text-muted">ID: @Model.AssetItem.AssetId</small>
        </div>
        <div>
            @if (User.IsInRole("Admin") || User.IsInRole("Manager"))
            {
                <a asp-page="Edit" asp-route-id="@Model.AssetItem.Id" class="btn btn-sm btn-primary" title="Edit">
                    <i class="fas fa-pencil"></i> Edit
                </a>
                <button type="button" class="btn btn-sm btn-danger" 
                        data-bs-toggle="modal" 
                        data-bs-target="#deleteModal"
                        title="Delete">
                    <i class="fas fa-trash"></i> Delete
                </button>
            }
        </div>
    </div>
    <div class="card-body">
        <div class="detail-row">
            <div class="detail-label">Asset ID</div>
            <div class="detail-value"><code>@Model.AssetItem.AssetId</code></div>
        </div>
        <div class="detail-row">
            <div class="detail-label">Type</div>
            <div class="detail-value">
                <span class="badge bg-info">@Model.AssetItem.Type</span>
            </div>
        </div>
        <div class="detail-row">
            <div class="detail-label">Priority</div>
            <div class="detail-value">
                @if (Model.AssetItem.Priority == AssetPriority.High)
                {
                    <span class="badge bg-danger">@Model.AssetItem.Priority</span>
                }
                else if (Model.AssetItem.Priority == AssetPriority.Medium)
                {
                    <span class="badge bg-warning text-dark">@Model.AssetItem.Priority</span>
                }
                else
                {
                    <span class="badge bg-success">@Model.AssetItem.Priority</span>
                }
            </div>
        </div>
        <div class="detail-row">
            <div class="detail-label">Integrity Status</div>
            <div class="detail-value">
                @if (Model.AssetItem.IntegrityStatus == IntegrityStatus.Good)
                {
                    <span class="badge bg-success">@Model.AssetItem.IntegrityStatus</span>
                }
                else if (Model.AssetItem.IntegrityStatus == IntegrityStatus.Fair)
                {
                    <span class="badge bg-warning text-dark">@Model.AssetItem.IntegrityStatus</span>
                }
                else
                {
                    <span class="badge bg-danger">@Model.AssetItem.IntegrityStatus</span>
                }
            </div>
        </div>
        <div class="detail-row">
            <div class="detail-label">Location</div>
            <div class="detail-value">@(string.IsNullOrEmpty(Model.AssetItem.Location) ? "-" : Model.AssetItem.Location)</div>
        </div>
        <div class="detail-row">
            <div class="detail-label">Description</div>
            <div class="detail-value">@(string.IsNullOrEmpty(Model.AssetItem.Description) ? "-" : Model.AssetItem.Description)</div>
        </div>
    </div>
</div>

<!-- Remarks Section -->
<div class="card shadow-sm mb-4">
    <div class="card-header bg-light">
        <h5 class="mb-0">
            <i class="fas fa-comments"></i> Remarks
            @if (Model.Remarks.Any())
            {
                <span class="badge bg-secondary">@Model.Remarks.Count</span>
            }
        </h5>
    </div>
    <div class="card-body">
        @if (!Model.Remarks.Any())
        {
            <div class="alert alert-info" role="alert">
                <i class="fas fa-circle-info"></i> No remarks yet. Be the first to add one!
            </div>
        }
        else
        {
            <div class="timeline-container">
                @foreach (var remark in Model.Remarks)
                {
                    <div class="remark-item">
                        <div class="d-flex justify-content-between align-items-center mb-1">
                            <span class="fw-bold"><i class="fas fa-user"></i> @(string.IsNullOrEmpty(remark.CreatedBy) ? "System" : remark.CreatedBy)</span>
                            <span class="remark-time"><i class="fas fa-clock"></i> @remark.CreatedAt.ToString("MMM dd, yyyy HH:mm")</span>
                        </div>
                        <div class="remark-content mt-0">
                            @remark.Description
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>

<!-- Add Remark Section -->
@if (User.IsInRole("Admin") || User.IsInRole("Manager") || User.IsInRole("User"))
{
    <div class="card shadow-sm">
        <div class="card-header bg-light">
            <h5 class="mb-0">
                <i class="fas fa-pen-to-square"></i> Add a Remark
            </h5>
        </div>
        <div class="card-body">
            <form method="post" asp-route-id="@Model.AssetItem.Id">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                <div class="mb-3">
                    <label asp-for="Input.Description" class="form-label">
                        <strong>Your Remark</strong>
                    </label>
                    <textarea asp-for="Input.Description" 
                              class="form-control" 
                              rows="4"
                              placeholder="Enter your remark about this asset item (max 250 characters)..."
                              style="resize: vertical;"></textarea>
                    <span asp-validation-for="Input.Description" class="d-block mt-1 text-danger"></span>
                    <small class="form-text text-muted mt-1">
                        Maximum 250 characters
                    </small>
                </div>

                <div class="form-group">
                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-paper-plane"></i> Add Remark
                    </button>
                    <a asp-page="Index" class="btn btn-outline-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
}

<!-- Delete Modal -->
@if (User.IsInRole("Admin") || User.IsInRole("Manager"))
{
    <div class="modal fade" id="deleteModal" tabindex="-1" aria-labelledby="deleteModalLabel" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="deleteModalLabel">Confirm Delete</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    Are you sure you want to delete the asset item "<strong>@Model.AssetItem.Title</strong>" (ID: @Model.AssetItem.AssetId)?
                    <br />
                    <span class="text-danger"><strong>This action cannot be undone.</strong></span>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <form method="post" asp-page="Delete" asp-route-id="@Model.AssetItem.Id" style="display:inline;">
                        <button type="submit" class="btn btn-danger">Delete</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
}

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
