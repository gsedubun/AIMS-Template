@page
@model AIMS.WebFrontend.Pages.AssetItems.IndexModel
@using AIMS.Core.Entities
@{
    ViewData["Title"] = "Asset Items";
}

<style>
    .filter-card {
        border-radius: 0.375rem;
        transition: box-shadow 0.3s ease;
    }

    .filter-card:hover {
        box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.15) !important;
    }

    .search-input-group .input-group-text {
        border-color: #dee2e6;
    }

    .badge-filter {
        display: inline-block;
        padding: 0.5rem 0.75rem;
        margin-right: 0.5rem;
        margin-bottom: 0.5rem;
        border-radius: 0.25rem;
    }

    .asset-type-pipe {
        background-color: #e7f3ff;
        color: #004085;
    }

    .asset-type-psv {
        background-color: #fff3cd;
        color: #856404;
    }

    .table-actions {
        white-space: nowrap;
    }

    .btn-group-sm .btn {
        padding: 0.25rem 0.5rem;
        font-size: 0.75rem;
    }
</style>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1><i class="bi bi-box-seam"></i> Asset Items</h1>
    @if (User.IsInRole("Admin") || User.IsInRole("Manager"))
    {
        <a asp-page="Create" class="btn btn-primary btn-lg">
            <i class="bi bi-plus-circle"></i> Add New Asset Item
        </a>
    }
</div>

<!-- Search and Filter Section -->
<div class="card mb-4 shadow-sm filter-card">
    <div class="card-header bg-light">
        <h5 class="mb-0">
            <i class="bi bi-funnel"></i> Search & Filter
        </h5>
    </div>
    <div class="card-body">
        <form method="get" id="filterForm">
            <div class="row g-3 mb-3">
                <!-- Primary Search Box -->
                <div class="col-md-12">
                    <label for="searchTerm" class="form-label"><strong>Search</strong></label>
                    <div class="input-group input-group-lg search-input-group">
                        <span class="input-group-text bg-light border-end-0">
                            <i class="bi bi-search"></i>
                        </span>
                        <input type="text" id="searchTerm" name="searchTerm" class="form-control border-start-0" 
                               placeholder="Search by Asset ID, Title, Description, or Location..." 
                               value="@Model.SearchTerm"
                               autocomplete="off">
                    </div>
                    <small class="form-text text-muted mt-1">
                        Searches across Asset ID, Title, Description, and Location fields
                    </small>
                </div>
            </div>

            <!-- Filter Controls -->
            <div class="row g-3">
                <div class="col-md-4">
                    <label for="typeFilter" class="form-label"><strong>Asset Type</strong></label>
                    <select id="typeFilter" name="typeFilter" class="form-select">
                        <option value="">All Types</option>
                        @foreach (AssetType type in Enum.GetValues(typeof(AssetType)))
                        {
                            <option value="@type" selected="@(Model.TypeFilter == type.ToString())">@type</option>
                        }
                    </select>
                </div>

                <div class="col-md-4">
                    <label for="priorityFilter" class="form-label"><strong>Priority</strong></label>
                    <select id="priorityFilter" name="priorityFilter" class="form-select">
                        <option value="">All Priorities</option>
                        @foreach (AssetPriority priority in Enum.GetValues(typeof(AssetPriority)))
                        {
                            <option value="@priority" selected="@(Model.PriorityFilter == priority.ToString())">@priority</option>
                        }
                    </select>
                </div>

                <div class="col-md-4">
                    <label for="statusFilter" class="form-label"><strong>Integrity Status</strong></label>
                    <select id="statusFilter" name="statusFilter" class="form-select">
                        <option value="">All Status</option>
                        @foreach (IntegrityStatus status in Enum.GetValues(typeof(IntegrityStatus)))
                        {
                            <option value="@status" selected="@(Model.StatusFilter == status.ToString())">@status</option>
                        }
                    </select>
                </div>
            </div>

            <!-- Action Buttons -->
            <div class="row g-2 mt-3">
                <div class="col-auto">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-search"></i> Apply Filters
                    </button>
                </div>
                <div class="col-auto">
                    <a asp-page="Index" class="btn btn-outline-secondary">
                        <i class="bi bi-arrow-counterclockwise"></i> Clear Filters
                    </a>
                </div>
            </div>
        </form>

        <!-- Active Filters Display -->
        @{
            var hasActiveFilters = !string.IsNullOrEmpty(Model.SearchTerm) || 
                                 !string.IsNullOrEmpty(Model.TypeFilter) || 
                                 !string.IsNullOrEmpty(Model.PriorityFilter) || 
                                 !string.IsNullOrEmpty(Model.StatusFilter);
        }
        @if (hasActiveFilters)
        {
            <div class="mt-3 pt-3 border-top">
                <small class="text-muted"><strong>Active Filters:</strong></small>
                <div class="mt-2">
                    @if (!string.IsNullOrEmpty(Model.SearchTerm))
                    {
                        <span class="badge bg-info text-dark">
                            Search: <strong>@Model.SearchTerm</strong>
                            <a href="@Url.Page("Index", new { typeFilter = Model.TypeFilter, priorityFilter = Model.PriorityFilter, statusFilter = Model.StatusFilter })" 
                               title="Remove search filter" style="margin-left: 5px; cursor: pointer;">
                                &times;
                            </a>
                        </span>
                    }
                    @if (!string.IsNullOrEmpty(Model.TypeFilter))
                    {
                        <span class="badge bg-info text-dark ms-1">
                            Type: <strong>@Model.TypeFilter</strong>
                            <a href="@Url.Page("Index", new { searchTerm = Model.SearchTerm, priorityFilter = Model.PriorityFilter, statusFilter = Model.StatusFilter })" 
                               title="Remove type filter" style="margin-left: 5px; cursor: pointer;">
                                &times;
                            </a>
                        </span>
                    }
                    @if (!string.IsNullOrEmpty(Model.PriorityFilter))
                    {
                        <span class="badge bg-info text-dark ms-1">
                            Priority: <strong>@Model.PriorityFilter</strong>
                            <a href="@Url.Page("Index", new { searchTerm = Model.SearchTerm, typeFilter = Model.TypeFilter, statusFilter = Model.StatusFilter })" 
                               title="Remove priority filter" style="margin-left: 5px; cursor: pointer;">
                                &times;
                            </a>
                        </span>
                    }
                    @if (!string.IsNullOrEmpty(Model.StatusFilter))
                    {
                        <span class="badge bg-info text-dark ms-1">
                            Status: <strong>@Model.StatusFilter</strong>
                            <a href="@Url.Page("Index", new { searchTerm = Model.SearchTerm, typeFilter = Model.TypeFilter, priorityFilter = Model.PriorityFilter })" 
                               title="Remove status filter" style="margin-left: 5px; cursor: pointer;">
                                &times;
                            </a>
                        </span>
                    }
                </div>
            </div>
        }
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-header bg-light">
        <div class="d-flex justify-content-between align-items-center">
            <h5 class="mb-0">
                <i class="bi bi-list"></i> Asset Items List
                @if (Model.AssetItems.Any())
                {
                    <span class="badge bg-secondary">@Model.AssetItems.Count result(s)</span>
                }
            </h5>
        </div>
    </div>
    <div class="card-body">
        @if (!Model.AssetItems.Any())
        {
            <div class="alert alert-info" role="alert">
                <i class="bi bi-info-circle"></i> No asset items found.
                @if (User.IsInRole("Admin") || User.IsInRole("Manager"))
                {
                    <a asp-page="Create" class="alert-link">Create one now</a>
                }
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-striped table-hover table-sm">
                    <thead class="table-dark">
                        <tr>
                            <th>Asset ID</th>
                            <th>Title</th>
                            <th>Type</th>
                            <th>Priority</th>
                            <th>Location</th>
                            <th>Integrity Status</th>
                            <th>Description</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.AssetItems)
                        {
                            <tr>
                                <td>
                                    <a asp-page="Details" asp-route-id="@item.Id" class="text-decoration-none">
                                        <code>@item.AssetId</code>
                                    </a>
                                </td>
                                <td>
                                    <a asp-page="Details" asp-route-id="@item.Id" class="text-decoration-none">@item.Title</a>
                                </td>
                                <td>
                                    <span class="badge bg-info">@item.Type</span>
                                </td>
                                <td>
                                    @if (item.Priority == AssetPriority.High)
                                    {
                                        <span class="badge bg-danger">@item.Priority</span>
                                    }
                                    else if (item.Priority == AssetPriority.Medium)
                                    {
                                        <span class="badge bg-warning text-dark">@item.Priority</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-success">@item.Priority</span>
                                    }
                                </td>
                                <td>@item.Location</td>
                                <td>
                                    @if (item.IntegrityStatus == IntegrityStatus.Good)
                                    {
                                        <span class="badge bg-success">@item.IntegrityStatus</span>
                                    }
                                    else if (item.IntegrityStatus == IntegrityStatus.Fair)
                                    {
                                        <span class="badge bg-warning text-dark">@item.IntegrityStatus</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">@item.IntegrityStatus</span>
                                    }
                                </td>
                                <td>
                                    <small>@(string.IsNullOrEmpty(item.Description) ? "-" : item.Description.Length > 50 ? item.Description.Substring(0, 50) + "..." : item.Description)</small>
                                </td>
                                <td class="table-actions">
                                    <div class="btn-group btn-group-sm">
                                        @if (User.IsInRole("Admin") || User.IsInRole("Manager"))
                                        {
                                            <a asp-page="Edit" asp-route-id="@item.Id" class="btn btn-outline-primary" title="Edit">
                                                <i class="bi bi-pencil"></i> Edit
                                            </a>
                                            <button type="button" class="btn btn-outline-danger" 
                                                    data-bs-toggle="modal" 
                                                    data-bs-target="#deleteModal-@item.Id.ToString().Replace("-", "")"
                                                    title="Delete">
                                                <i class="bi bi-trash"></i> Delete
                                            </button>
                                        }
                                        else
                                        {
                                            <span class="text-muted">View only</span>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <!-- Pagination -->
            @if (Model.TotalPages > 1)
            {
                <nav aria-label="Page navigation" class="mt-4">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <small class="text-muted">
                            Showing page @Model.CurrentPage of @Model.TotalPages
                        </small>
                    </div>
                    <ul class="pagination justify-content-center">
                        @if (Model.CurrentPage > 1)
                        {
                            <li class="page-item">
                                <a class="page-link" asp-page="Index" asp-route-page="1" asp-route-searchTerm="@Model.SearchTerm" asp-route-typeFilter="@Model.TypeFilter" asp-route-priorityFilter="@Model.PriorityFilter" asp-route-statusFilter="@Model.StatusFilter">
                                    <i class="bi bi-chevron-double-left"></i>
                                </a>
                            </li>
                            <li class="page-item">
                                <a class="page-link" asp-page="Index" asp-route-page="@(Model.CurrentPage - 1)" asp-route-searchTerm="@Model.SearchTerm" asp-route-typeFilter="@Model.TypeFilter" asp-route-priorityFilter="@Model.PriorityFilter" asp-route-statusFilter="@Model.StatusFilter">
                                    <i class="bi bi-chevron-left"></i>
                                </a>
                            </li>
                        }
                        @for (int i = 1; i <= Model.TotalPages; i++)
                        {
                            <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                                <a class="page-link" asp-page="Index" asp-route-page="@i" asp-route-searchTerm="@Model.SearchTerm" asp-route-typeFilter="@Model.TypeFilter" asp-route-priorityFilter="@Model.PriorityFilter" asp-route-statusFilter="@Model.StatusFilter">@i</a>
                            </li>
                        }
                        @if (Model.CurrentPage < Model.TotalPages)
                        {
                            <li class="page-item">
                                <a class="page-link" asp-page="Index" asp-route-page="@(Model.CurrentPage + 1)" asp-route-searchTerm="@Model.SearchTerm" asp-route-typeFilter="@Model.TypeFilter" asp-route-priorityFilter="@Model.PriorityFilter" asp-route-statusFilter="@Model.StatusFilter">
                                    <i class="bi bi-chevron-right"></i>
                                </a>
                            </li>
                            <li class="page-item">
                                <a class="page-link" asp-page="Index" asp-route-page="@Model.TotalPages" asp-route-searchTerm="@Model.SearchTerm" asp-route-typeFilter="@Model.TypeFilter" asp-route-priorityFilter="@Model.PriorityFilter" asp-route-statusFilter="@Model.StatusFilter">
                                    <i class="bi bi-chevron-double-right"></i>
                                </a>
                            </li>
                        }
                    </ul>
                </nav>
            }
        }
    </div>
</div>

<!-- Delete Modals -->
@foreach (var item in Model.AssetItems)
{
    <div class="modal fade" id="deleteModal-@item.Id.ToString().Replace("-", "")" tabindex="-1" aria-labelledby="deleteModalLabel" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="deleteModalLabel">Confirm Delete</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    Are you sure you want to delete the asset item "<strong>@item.Title</strong>" (ID: @item.AssetId)?
                    <br />
                    <span class="text-danger">This action cannot be undone.</span>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <form method="post" asp-page="Delete" asp-route-id="@item.Id" style="display:inline;">
                        <button type="submit" class="btn btn-danger">Delete</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
}
